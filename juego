            width=108,
            padding=10,
            border_radius=18,
            bgcolor=char["color"] + "22",
            border=ft.border.all(1, "#FFFFFF33"),
            on_click=on_tap,
        )
        card_containers.append(card)
        return card

    cards = [make_card(ch, i) for i, ch in enumerate(CHARACTERS)]

