def get_bg(meters):
    for b in BACKGROUNDS:
        if b["min_m"] <= meters < b["max_m"]:
            return b
    return BACKGROUNDS[-1]


# =============================================
#               CLASES DEL JUEGO
# =============================================
class Platform:
    def __init__(self, x, y, w, moving=False):
        self.x = x
        self.y = y
        self.w = w
        self.moving = moving
        self.dir = 1
        self.speed = random.uniform(1.2, 2.5) if moving else 0

    def update(self, screen_w):
        if self.moving:
            self.x += self.dir * self.speed
            if self.x < 0:
                self.dir = 1
            if self.x + self.w > screen_w:
                self.dir = -1


class GameState:
    def __init__(self):
        self.player_name = ""
        self.selected_char = None
        self.player_x = 0.0
        self.player_y = 0.0
        self.player_vx = 0.0
        self.player_vy = 0.0
        self.player_facing = 1
        self.platforms = []
        self.camera_y = 0.0
        self.meters = 0
        self.alive = True
        self.left_held = False
        self.right_held = False
        self.arrow_size = 64
        self.game_running = False
        self.screen_w = 400
        self.screen_h = 720
        self.star_positions = []


def init_game(state, sw, sh):
    sw = int(sw)
    sh = int(sh)
    state.screen_w = sw
    state.screen_h = sh
    state.player_x = float(sw // 2 - PLAYER_W // 2)
    state.player_y = float(sh - 120)
    state.player_vx = 0.0
    state.player_vy = JUMP_FORCE
    state.player_facing = 1
    state.camera_y = 0.0
    state.meters = 0
    state.alive = True
    state.left_held = False
    state.right_held = False

    gap_y = sh // (PLATFORM_COUNT + 1)
    state.platforms = []
    for i in range(PLATFORM_COUNT):
        pw = random.randint(65, 115)
        max_x = int(max(11, sw - pw - 10))
        px = random.randint(10, max_x)
        py = sh - 80 - i * gap_y
        moving = i > 4 and random.random() < 0.25
        state.platforms.append(Platform(px, float(py), pw, moving))

    state.star_positions = [
        (random.randint(0, int(sw)), random.randint(0, int(sh)))
        for _ in range(40)
    ]


