        on_tap_up=set_right_up,
        on_horizontal_drag_start=set_right_down,
        on_horizontal_drag_end=set_right_up,
    )

    arrow_row = ft.Container(
        content=ft.Row(
            controls=[left_btn, ft.Container(expand=True), right_btn],
            alignment=ft.MainAxisAlignment.SPACE_BETWEEN,
        ),
        bottom=24,
        left=20,
        right=20,
    )

    game_stack = ft.Stack(
        controls=[
            bg_ctrl,
            *star_ctrls,
            *plat_ctrls,
            player_ctrl,
            meter_display,
            name_display,
            settings_btn,
            arrow_row,
        ],
        expand=True,
    )

    # -------- BUCLE DEL JUEGO (Thread) --------
    scroll_line = sh * 0.38
    world_top = [float(sh - 80)]

    def game_loop():
        while state.game_running and state.alive:
            bg = get_bg(state.meters)
            speed = char["speed"]

            # Movimiento horizontal
            if state.left_held:
                state.player_vx = -speed
                state.player_facing = -1
            elif state.right_held:
                state.player_vx = speed
                state.player_facing = 1
            else:
                state.player_vx *= 0.7

            state.player_x += state.player_vx
            state.player_vy += GRAVITY
            state.player_y += state.player_vy

            # Envolver en los bordes horizontales
            if state.player_x + PLAYER_W < 0:
                state.player_x = float(sw)
            if state.player_x > sw:
                state.player_x = float(-PLAYER_W)

            # Scroll de cámara
            if state.player_y < scroll_line:
                delta = scroll_line - state.player_y
                state.player_y = scroll_line
                state.camera_y += delta
                world_top[0] += delta
                for p in state.platforms:
                    p.y += delta

            # Contador de metros
            new_m = int(state.camera_y / 8)
            if new_m > state.meters:
                state.meters = new_m

            # Colisión con plataformas (solo bajando)
            if state.player_vy > 0:
                for p in state.platforms:
                    if (
                        state.player_x + PLAYER_W > p.x + 6
                        and state.player_x < p.x + p.w - 6
                        and state.player_y + PLAYER_H >= p.y
                        and state.player_y + PLAYER_H <= p.y + PLAT_H + 12
                    ):
                        state.player_vy = JUMP_FORCE - char["jump_bonus"]

            # Mover plataformas móviles
            for p in state.platforms:
                p.update(sw)

            # Regenerar plataformas que salen por abajo
            for p in state.platforms:
                if p.y > sh + 20:
                    pw2 = random.randint(65, 115)
                    max_x2 = int(max(11, sw - pw2 - 10))
                    p.x = float(random.randint(10, max_x2))
                    p.y = world_top[0] - float(random.randint(60, 145))
                    p.w = pw2
                    p.moving = state.meters > 300 and random.random() < 0.3
                    p.speed = random.uniform(1.2, 3.0)
                    world_top[0] = min(world_top[0], p.y)

            # Comprobar si cayó
            if state.player_y > sh + 100:
                state.alive = False
                state.game_running = False
                break

            # --- ACTUALIZAR CONTROLES VISUALES ---
            bg_ctrl.gradient = ft.LinearGradient(
                colors=[bg["bg_top"], bg["bg_bot"]],
            )

            show_stars = bg["stars"]
            for i, sc in enumerate(star_ctrls):
                if show_stars:
                    sx, sy = state.star_positions[i]
                    sc.left = float(sx)
                    sc.top = float(sy)
                    sc.opacity = 0.85
                else:
                    sc.opacity = 0.0

            for p, pc in zip(state.platforms, plat_ctrls):
                pc.left = float(p.x)
                pc.top = float(p.y)
                pc.width = float(p.w)
                pc.bgcolor = bg["plat_color"]
                pc.border = ft.border.all(2, bg["plat_edge"])

            player_ctrl.left = float(state.player_x)
            player_ctrl.top = float(state.player_y)

            meter_text.value = f"{state.meters}m"
            bg_label_text.value = bg["label"]

            try:
                page.update()
            except Exception:
                break

            time.sleep(FPS)

        # Fin del juego
        if not state.alive:
            try:
                go_game_over()
            except Exception:
                pass

    return game_stack, game_loop


# =============================================
#              FUNCIÓN PRINCIPAL
# =============================================
def main(page: ft.Page):
    page.title = "BOZA"
    page.theme_mode = ft.ThemeMode.DARK
    page.bgcolor = "#0D0221"
    page.padding = 0
    page.spacing = 0

    state = GameState()
    settings_origin = ["start"]

    def get_page_size():
        try:
            w = page.window.width
            h = page.window.height
            if w and int(w) > 100:
                state.screen_w = int(w)
            if h and int(h) > 200:
                state.screen_h = int(h)
        except Exception:
            pass

    def show(control):
        page.controls.clear()
        page.controls.append(control)
        page.update()

    def go_start():
        state.game_running = False
        get_page_size()
        scr = build_start_screen(page, state, go_select, go_settings)
        show(scr)

    def go_select():
        get_page_size()
        scr = build_char_select(page, state, go_game, go_start)
        show(scr)

    def go_settings(origin="start"):
        settings_origin[0] = origin
        state.game_running = False
        scr = build_settings_screen(page, state, go_back_from_settings)
        show(scr)

    def go_back_from_settings():
        if settings_origin[0] == "game":
            go_select()
        else:
            go_start()

    def go_game():
        state.game_running = False
        time.sleep(0.06)
        get_page_size()
        state.selected_char = state.selected_char or CHARACTERS[0]
        init_game(state, state.screen_w, state.screen_h)

        game_view, loop_fn = build_game_view(
            page, state, go_game_over, lambda: go_settings("game")
        )
        show(game_view)

        state.game_running = True
        t = threading.Thread(target=loop_fn, daemon=True)
        t.start()

    def go_game_over():
        state.game_running = False
        scr = build_game_over_screen(page, state, go_game, go_start)
        show(scr)

    def on_resize(e):
        try:
            w = page.window.width
            h = page.window.height
            if w and int(w) > 100:
                state.screen_w = int(w)
            if h and int(h) > 200:
                state.screen_h = int(h)
        except Exception:
            pass

    page.on_resized = on_resize

    go_start()


ft.app(target=main)
