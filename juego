    def make_card(char, idx):
        def on_tap(e, cidx=idx, c=char):
            state.selected_char = c
            for i, cc in enumerate(card_containers):
                cc.border = (
                    ft.border.all(3, "#FFD700")
                    if i == cidx
                    else ft.border.all(1, "#FFFFFF33")
                )
                cc.bgcolor = (
                    c["color"] + "55" if i == cidx else c["color"] + "22"
                )
            page.update()

        card = ft.Container(
            content=ft.Column(
                controls=[
                    ft.Text(char["emoji"], size=52, text_align=ft.TextAlign.CENTER),
                    ft.Text(char["badge"], size=22, text_align=ft.TextAlign.CENTER),
                    ft.Text(
                        char["name"],
                        size=15,
                        weight=ft.FontWeight.W_900,
                        color="#FFFFFF",
